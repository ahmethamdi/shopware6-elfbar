{% sw_extends '@Storefront/storefront/layout/header/actions/cart-widget.html.twig' %}

{# ElfbarTheme: sepet ikonunun köşesine BELİRGİN adet rozeti (toplam adet).
   Böylece header € tutarının kaç üründen geldiği bir bakışta anlaşılır.
   frontend.checkout.info bu template'i döndürür → +/− sonrası rozet de tazelenir. #}
{% block layout_header_actions_cart_widget %}
    {% set elfbarCartCount = 0 %}
    {% for lineItem in page.cart.lineItems %}
        {% set elfbarCartCount = elfbarCartCount + lineItem.quantity %}
    {% endfor %}

    <span class="header-cart-icon elfbar-cart-icon-wrap">
        {% sw_icon 'bag' %}
        {% if elfbarCartCount > 0 %}
            <span class="elfbar-cart-count" aria-hidden="true">{{ elfbarCartCount > 99 ? '99+' : elfbarCartCount }}</span>
        {% endif %}
    </span>

    {% if page.cart.lineItems|length > 0 %}
        <span class="badge bg-primary header-cart-badge visually-hidden">{{ page.cart.lineItems|length }}</span>
    {% endif %}

    <span class="header-cart-total d-none d-sm-inline-block ms-sm-2">
        {{ page.cart.price.positionPrice|currency }}
    </span>

    <span class="visually-hidden" id="cart-widget-aria-label">
        {{ 'checkout.cartScreenReaderUpdate'|trans({
                '%count%': page.cart.lineItems|length,
                '%total%': page.cart.price.positionPrice|currency,
            })|sw_sanitize }}
    </span>
{% endblock %}

{# =====================================================================
   ElfbarTheme — Mega menü (sol kategori ağacı + hover'da açılan panel)
   DİNAMİK: kategoriler canlı navigasyondan gelir (elfbarNavTree =
   page.extensions.elfbarNavTree.tree, subscriber → NavigationLoader).
   Her ana kategorinin gerçek alt kategorileri + SEO URL'leri kullanılır.
   Sağ promo alanı theme_config'ten (Mega-Menü Bilder bloğu, loop.index).
   Parametreler:
     elfbarNavTree (zorunlu) — TreeItem listesi (category + children)
     activeId (opsiyonel) — aktif kategori vurgusu
   ===================================================================== #}
<nav class="elfbar-mega" data-elfbar-mega aria-label="Kategorien">
    <ul class="elfbar-mega__list">
        {% for treeItem in elfbarNavTree|default([]) %}
            {% set cat = treeItem.category %}
            {% set megaIdx = loop.index %}
            {% set catName = cat.translated.name %}
            {% set catUrl = cat.type == 'folder' ? '#' : (cat.seoUrl ?: seoUrl('frontend.navigation.page', { navigationId: cat.id })) %}
            {% set children = treeItem.children|default([]) %}
            {% set hasChildren = children|length > 0 %}
            {% set isActive = (activeId is defined and activeId == cat.id) %}
            <li class="elfbar-mega__item{{ hasChildren ? ' has-children' : '' }}">
                <a class="elfbar-mega__link{{ isActive ? ' is-active' : '' }}" href="{{ catUrl }}">
                    <span class="elfbar-mega__name">{{ catName }}</span>
                    {% if hasChildren %}<span class="elfbar-mega__caret" aria-hidden="true">›</span>{% endif %}
                </a>

                {% if hasChildren %}
                    <div class="elfbar-mega__panel">
                        <div class="elfbar-mega__panel-head">
                            <span class="elfbar-mega__heading">{{ catName }}</span>
                            <a href="{{ catUrl }}" class="elfbar-mega__all">Alle anzeigen →</a>
                        </div>
                        <div class="elfbar-mega__body">
                            {# Alt kategoriler + (varsa) 3. seviye alt-alt kategoriler.
                               Alt-altı olan kategori grup başlığı olur, altında liste;
                               alt-altı olmayan tek link kalır (eskisi gibi). #}
                            <div class="elfbar-mega__grid">
                                {% for childItem in children %}
                                    {% set child = childItem.category %}
                                    {% set childUrl = child.type == 'folder' ? '#' : (child.seoUrl ?: seoUrl('frontend.navigation.page', { navigationId: child.id })) %}
                                    {% set grandChildren = childItem.children|default([]) %}
                                    {% if grandChildren|length > 0 %}
                                        <div class="elfbar-mega__group">
                                            <a href="{{ childUrl }}" class="elfbar-mega__cell elfbar-mega__cell--head">{{ child.translated.name }}</a>
                                            <ul class="elfbar-mega__sublist">
                                                {% for gcItem in grandChildren %}
                                                    {% set gc = gcItem.category %}
                                                    {% set gcUrl = gc.type == 'folder' ? '#' : (gc.seoUrl ?: seoUrl('frontend.navigation.page', { navigationId: gc.id })) %}
                                                    <li><a href="{{ gcUrl }}" class="elfbar-mega__sublink">{{ gc.translated.name }}</a></li>
                                                {% endfor %}
                                            </ul>
                                        </div>
                                    {% else %}
                                        <a href="{{ childUrl }}" class="elfbar-mega__cell">{{ child.translated.name }}</a>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                {% endif %}
            </li>
        {% endfor %}
    </ul>
</nav>

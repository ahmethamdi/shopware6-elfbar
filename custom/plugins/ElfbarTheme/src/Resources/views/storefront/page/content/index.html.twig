{% sw_extends '@Storefront/storefront/page/content/index.html.twig' %}

{# Gerçek üründen .elfbar-pcard kartı üretir (Bestseller + Neuheiten ortak).
   product = SalesChannelProductEntity, loggedIn = B2B gate, badge = 'Neu'/'Top' vb. #}
{% macro elfbarProductCard(product, loggedIn, badge) %}
    {% set pName = product.translated.name ?? product.name %}
    {% set pBrand = product.manufacturer ? (product.manufacturer.translated.name ?? product.manufacturer.name) : '' %}
    {% set pCover = product.cover.media ?? null %}
    {% set pPrice = product.calculatedCheapestPrice ?? product.calculatedPrice %}
    {% set pUrl = path('frontend.detail.page', { productId: product.id }) %}
    <a href="{{ pUrl }}" class="elfbar-pcard">
        {% if badge %}<span class="elfbar-pcard__badge">{{ badge }}</span>{% endif %}
        <span class="elfbar-pcard__age">18+</span>
        <div class="elfbar-pcard__img">
            {% if pCover %}
                {% sw_thumbnails 'elfbar-pcard-img' with {
                    media: pCover,
                    sizes: { default: '240px' }
                } %}
            {% else %}<svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>{% endif %}
        </div>
        {# NUR echte Bewertungen, keine Fake-Sterne (Wunsch Ahmet/Mike) #}
        {% if product.ratingAverage > 0 %}
            <div class="elfbar-pcard__stars">
                {% sw_include '@Storefront/storefront/component/review/rating.html.twig' with { points: product.ratingAverage } %}
            </div>
        {% endif %}
        {% if pBrand %}<div class="elfbar-pcard__brand">{{ pBrand }}</div>{% endif %}
        <div class="elfbar-pcard__name">{{ pName }}</div>
        <div class="elfbar-pcard__foot">
            {% if loggedIn %}
                <span class="elfbar-pcard__price">{{ pPrice.unitPrice|currency }}</span>
                <span class="elfbar-pcard__add" aria-hidden="true">+</span>
            {% else %}
                <span class="elfbar-pcard__price is-login">{% sw_icon 'lock-closed' %} Login</span>
                <span class="elfbar-pcard__add is-login" aria-hidden="true">{% sw_icon 'lock-closed' %}</span>
            {% endif %}
        </div>
    </a>
{% endmacro %}

{# Kategori vitrini: SOL gradient kategori görsel kartı + SAĞ yatay ürün slider.
   products = ürün listesi, loggedIn = B2B gate, badge, tone = renk varyantı,
   catName/catSub/catLink = sol kart metinleri. #}
{% macro elfbarCatSlider(products, loggedIn, badge, tone, catName, catSub, catLink, eyebrow, img) %}
    <section class="elfbar-catslider">
        <a href="{{ catLink ?: '#' }}" class="elfbar-catslider__feature elfbar-catslider__feature--{{ tone }}{% if img %} has-image{% endif %}">
            {# Panelden görsel yüklenmişse gradient+harf yerine görsel arka plan.
               Metinlerin okunması için üstüne koyu degrade overlay biner. #}
            {% if img %}
                <img class="elfbar-catslider__bg" src="{{ img }}" alt="{{ catName }}" loading="lazy">
                <span class="elfbar-catslider__overlay" aria-hidden="true"></span>
            {% endif %}
            <span class="elfbar-catslider__eyebrow">{{ eyebrow|default('Kategorie') }}</span>
            <span class="elfbar-catslider__name">{{ catName }}</span>
            <span class="elfbar-catslider__sub">{{ catSub }}</span>
            <span class="elfbar-catslider__cta">Alle anzeigen {% sw_icon 'arrow-right' %}</span>
            {% if not img %}<span class="elfbar-catslider__glyph" aria-hidden="true">{{ catName|first|upper }}</span>{% endif %}
        </a>
        <div class="elfbar-catslider__main">
            <div class="elfbar-catslider__head">
                <h2 class="elfbar-catslider__title">{{ catName }}</h2>
                <div class="elfbar-slider-nav">
                    <button type="button" class="elfbar-slider-btn" data-slide="prev" aria-label="Zurück"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 6 9 12 15 18"/></svg></button>
                    <button type="button" class="elfbar-slider-btn" data-slide="next" aria-label="Weiter"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg></button>
                </div>
            </div>
            <div class="elfbar-cardslider" data-elfbar-cardslider>
                <div class="elfbar-cardslider__track">
                    {% for product in products %}
                        {{ _self.elfbarProductCard(product, loggedIn, badge) }}
                    {% endfor %}
                </div>
            </div>
        </div>
    </section>
{% endmacro %}

{# =====================================================================
   ElfbarTheme — Anasayfa (MOCKUP birebir):
   HERO (köşeli, üstte) → hemen altında 2 kolon:
   SOL = sidebar (HOME + kategoriler) | SAĞ = marka ikonları + promo + bestseller + deals
   Full ekran DEĞİL — container içinde.
   ===================================================================== #}
{% block cms_content %}
    {% set elfbarIsHome = shopware.navigation.id == context.salesChannel.navigationCategoryId %}
    {# B2B: Preise nur für eingeloggte Kunden sichtbar. #}
    {% set elfbarLoggedIn = context.customer %}
    {# Dinamik kategori ağacı (subscriber → NavigationLoader). Boşsa Twig fallback ([]). #}
    {% set elfbarNavTree = page.extensions.elfbarNavTree.tree|default([]) %}

    {% if elfbarIsHome %}
        {% set mediaSvg %}<svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>{% endset %}

        {# Panelden yönetilen section görünürlük + sıra okuyucular.
           secOn('x') → bool (boşsa varsayılan açık), secOrder('x') → int sıra. #}
        {% set elfbarSecOrderDefaults = {
            'catscroll': 3, 'vitrine': 10, 'campaign': 20, 'promo': 30, 'catslider2': 35, 'deals': 40, 'whyus': 45, 'banner': 50,
            'neu': 60, 'showcase': 70, 'bestseller': 80, 'b2b': 90, 'catslider1': 100,
            'usp': 110, 'stripe2': 130, 'howtofaq': 140, 'reviews': 150
        } %}

        <div class="elfbar-page">
            {# ============ HERO (köşeli, üstte, tam genişlik) ============ #}
            {% if theme_config('elfbar-sec-hero-enabled') is not same as(false) %}
            {% block elfbar_home_hero %}
                <section class="elfbar-hero">
                    <div class="elfbar-hero__content">
                        {% if theme_config('elfbar-hero-eyebrow') %}<span class="elfbar-hero__eyebrow">{{ theme_config('elfbar-hero-eyebrow') }}</span>{% endif %}
                        {% if theme_config('elfbar-hero-title') %}<h1 class="elfbar-hero__title">{{ theme_config('elfbar-hero-title')|raw }}</h1>{% endif %}
                        {% if theme_config('elfbar-hero-subtitle') %}<p class="elfbar-hero__subtitle">{{ theme_config('elfbar-hero-subtitle') }}</p>{% endif %}
                        {% if theme_config('elfbar-hero-cta') %}<a href="{{ theme_config('elfbar-hero-cta-link') ?: path('frontend.account.register.page') }}" class="btn elfbar-hero__cta">{{ theme_config('elfbar-hero-cta') }}</a>{% endif %}
                    </div>
                    {# Mobilde ayrı görsel: panelde "(Mobil)" alanı doluysa telefonda O gösterilir
                       (desktop görseli mobilde gizlenir). Boşsa desktop görseli mobilde de görünür. #}
                    <div class="elfbar-hero__media">
                        {% set heroBig      = theme_config('elfbar-hero-img-big') %}
                        {% set heroSmall1   = theme_config('elfbar-hero-img-small-1') %}
                        {% set heroSmall2   = theme_config('elfbar-hero-img-small-2') %}
                        {% set heroBigMob    = theme_config('elfbar-hero-img-big-mobile') %}
                        {% set heroSmall1Mob = theme_config('elfbar-hero-img-small-1-mobile') %}
                        {% set heroSmall2Mob = theme_config('elfbar-hero-img-small-2-mobile') %}
                        {# Görsel linkleri (panelden). Doluysa görsel <a> ile sarılır, boşsa düz div. #}
                        {% set heroBigLink    = theme_config('elfbar-hero-img-big-link') %}
                        {% set heroSmall1Link = theme_config('elfbar-hero-img-small-1-link') %}
                        {% set heroSmall2Link = theme_config('elfbar-hero-img-small-2-link') %}

                        {% set heroBigTag = heroBigLink ? 'a' : 'div' %}
                        <{{ heroBigTag }}{% if heroBigLink %} href="{{ heroBigLink }}"{% endif %} class="elfbar-hero__media-big{% if heroBigMob %} has-mobile{% endif %}">
                            {% if heroBig %}<img class="elfbar-hero__img elfbar-hero__img--desktop" src="{{ heroBig }}" alt="" loading="lazy">{% elseif not heroBigMob %}{{ mediaSvg }}{% endif %}
                            {% if heroBigMob %}<img class="elfbar-hero__img elfbar-hero__img--mobile" src="{{ heroBigMob }}" alt="" loading="lazy">{% endif %}
                        </{{ heroBigTag }}>
                        {% set heroS1Tag = heroSmall1Link ? 'a' : 'div' %}
                        <{{ heroS1Tag }}{% if heroSmall1Link %} href="{{ heroSmall1Link }}"{% endif %} class="elfbar-hero__media-small{% if heroSmall1Mob %} has-mobile{% endif %}">
                            {% if heroSmall1 %}<img class="elfbar-hero__img elfbar-hero__img--desktop" src="{{ heroSmall1 }}" alt="" loading="lazy">{% elseif not heroSmall1Mob %}{{ mediaSvg }}{% endif %}
                            {% if heroSmall1Mob %}<img class="elfbar-hero__img elfbar-hero__img--mobile" src="{{ heroSmall1Mob }}" alt="" loading="lazy">{% endif %}
                        </{{ heroS1Tag }}>
                        {% set heroS2Tag = heroSmall2Link ? 'a' : 'div' %}
                        <{{ heroS2Tag }}{% if heroSmall2Link %} href="{{ heroSmall2Link }}"{% endif %} class="elfbar-hero__media-small{% if heroSmall2Mob %} has-mobile{% endif %}">
                            {% if heroSmall2 %}<img class="elfbar-hero__img elfbar-hero__img--desktop" src="{{ heroSmall2 }}" alt="" loading="lazy">{% elseif not heroSmall2Mob %}{{ mediaSvg }}{% endif %}
                            {% if heroSmall2Mob %}<img class="elfbar-hero__img elfbar-hero__img--mobile" src="{{ heroSmall2Mob }}" alt="" loading="lazy">{% endif %}
                        </{{ heroS2Tag }}>
                    </div>
                </section>
            {% endblock %}
            {% endif %}


            {# ============ 2 KOLON: SOL sidebar | SAĞ içerik ============ #}
            {% set elfbarSidebarOn = theme_config('elfbar-sec-sidebar-enabled') is not same as(false) %}
            <div class="elfbar-body{% if not elfbarSidebarOn %} elfbar-body--nosidebar{% endif %}">
                {# --- SOL: SİDEBAR --- #}
                {% if elfbarSidebarOn %}
                {% block elfbar_home_sidebar %}
                    <aside class="elfbar-sidebar">
                        <div class="elfbar-sidebar__head">Alle Kategorien</div>
                        {% sw_include '@Storefront/storefront/component/elfbar/megamenu.html.twig' with { elfbarNavTree: elfbarNavTree } %}
                        <div class="elfbar-sidebar__promo">{% if theme_config('elfbar-sidebar-promo-img') %}<img src="{{ theme_config('elfbar-sidebar-promo-img') }}" alt="" loading="lazy">{% else %}{{ mediaSvg }}{% endif %}</div>

                        {# Dikey kampanya banner — başlık boşsa tüm CTA gizli #}
                        {% if theme_config('elfbar-sidebar-cta-title') or theme_config('elfbar-sidebar-cta-btn') %}
                            <a href="{{ path('frontend.account.register.page') }}" class="elfbar-sidebar__cta">
                                {% if theme_config('elfbar-sidebar-cta-eyebrow') %}<span class="elfbar-sidebar__cta-eyebrow">{{ theme_config('elfbar-sidebar-cta-eyebrow') }}</span>{% endif %}
                                {% if theme_config('elfbar-sidebar-cta-title') %}<span class="elfbar-sidebar__cta-title">{{ theme_config('elfbar-sidebar-cta-title') }}</span>{% endif %}
                                {% if theme_config('elfbar-sidebar-cta-btn') %}<span class="elfbar-sidebar__cta-btn">{{ theme_config('elfbar-sidebar-cta-btn') }}</span>{% endif %}
                            </a>
                        {% endif %}

                        {# USP listesi — başlığı boş olan madde gizli; hepsi boşsa liste gizli #}
                        {% set elfbarUsps = [] %}
                        {% for u in [
                            { i: 'truck', t: theme_config('elfbar-usp-1-title'), s: theme_config('elfbar-usp-1-sub') },
                            { i: 'lock-closed', t: theme_config('elfbar-usp-2-title'), s: theme_config('elfbar-usp-2-sub') },
                            { i: 'arrow-circle-left', t: theme_config('elfbar-usp-3-title'), s: theme_config('elfbar-usp-3-sub') },
                            { i: 'headset', t: theme_config('elfbar-usp-4-title'), s: theme_config('elfbar-usp-4-sub') }
                        ] %}
                            {% if u.t %}{% set elfbarUsps = elfbarUsps|merge([u]) %}{% endif %}
                        {% endfor %}
                        {% if elfbarUsps|length %}
                            <ul class="elfbar-sidebar__usp">
                                {% for usp in elfbarUsps %}
                                    <li class="elfbar-sidebar__usp-item">
                                        <span class="elfbar-sidebar__usp-ico">{% sw_icon usp.i %}</span>
                                        <span class="elfbar-sidebar__usp-txt">
                                            <b>{{ usp.t }}</b>
                                            {% if usp.s %}<small>{{ usp.s }}</small>{% endif %}
                                        </span>
                                    </li>
                                {% endfor %}
                            </ul>
                        {% endif %}
                    </aside>
                {% endblock %}
                {% endif %}

                {# --- SAĞ: section'lar. Sıra panelden (CSS order), her biri aç/kapa.
                       body__main flex-column → her section'a style="order:N" ile sıralanır. --- #}
                <div class="elfbar-body__main elfbar-body__main--ordered">
                    {# ============ KATEGORIE-SCROLL — yatay kaydırılabilir kartlar (hero altı).
                       PANELDEN 8 slot: her biri görsel + başlık + link (elfbar-catscroll-N-*).
                       Başlık VE görsel boşsa slot gizli. Ok butonları data-elfbar-cardslider JS. ============ #}
                    {% if theme_config('elfbar-sec-catscroll-enabled') is not same as(false) %}
                    {% set csCards = [] %}
                    {% for i in 1..8 %}
                        {% set csT = theme_config('elfbar-catscroll-' ~ i ~ '-title') %}
                        {% set csI = theme_config('elfbar-catscroll-' ~ i ~ '-img') %}
                        {% if csT or csI %}
                            {% set csCards = csCards|merge([{ title: csT, img: csI, link: theme_config('elfbar-catscroll-' ~ i ~ '-link') }]) %}
                        {% endif %}
                    {% endfor %}
                    {% if csCards|length %}
                    <div class="elfbar-sec" style="order: {{ theme_config('elfbar-sec-catscroll-order')|default(elfbarSecOrderDefaults.catscroll) }}">
                    {% block elfbar_home_catscroll %}
                        <section class="elfbar-catscroll" aria-labelledby="elfbar-catscroll-title">
                            <div class="elfbar-catscroll__head">
                                <div class="elfbar-catscroll__titles">
                                    {% if theme_config('elfbar-catscroll-eyebrow')|default('Sortiment') %}<p class="elfbar-catscroll__eyebrow">{{ theme_config('elfbar-catscroll-eyebrow')|default('Sortiment') }}</p>{% endif %}
                                    <h2 class="elfbar-catscroll__title" id="elfbar-catscroll-title">{{ theme_config('elfbar-catscroll-title')|default('Nach Kategorie shoppen') }}</h2>
                                </div>
                                <div class="elfbar-catscroll__nav">
                                    <button type="button" class="elfbar-catscroll__btn" data-slide="prev" aria-label="Zurück"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 6 9 12 15 18"/></svg></button>
                                    <button type="button" class="elfbar-catscroll__btn" data-slide="next" aria-label="Weiter"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg></button>
                                </div>
                            </div>
                            <div class="elfbar-catscroll__track" data-elfbar-cardslider>
                                {% for c in csCards %}
                                    {% set csTag = c.link ? 'a' : 'div' %}
                                    <{{ csTag }} class="elfbar-catcard"{% if c.link %} href="{{ c.link }}"{% endif %}>
                                        {% if c.img %}
                                            <span class="elfbar-catcard__img"><img src="{{ c.img }}" alt="{{ c.title }}" loading="lazy"></span>
                                        {% else %}
                                            <span class="elfbar-catcard__letter">{{ c.title|first|upper }}</span>
                                        {% endif %}
                                        {% if c.title %}<span class="elfbar-catcard__name">{{ c.title }}</span>{% endif %}
                                    </{{ csTag }}>
                                {% endfor %}
                            </div>
                        </section>
                    {% endblock %}
                    </div>
                    {% endif %}
                    {% endif %}

                    {# ============ WARUM WIR — bilgi/güven section (hero altı, klasik)
                       3 avantaj kartı, her biri başlık+metin+3 madde. Tümü panelden. ============ #}
                    {% if theme_config('elfbar-sec-whyus-enabled') is not same as(false) %}
                    <div class="elfbar-sec" style="order: {{ theme_config('elfbar-sec-whyus-order')|default(elfbarSecOrderDefaults.whyus) }}">
                    {% block elfbar_home_whyus %}
                        {% set wuCards = [
                            {
                                icon: theme_config('elfbar-whyus-1-icon')|default('shield'),
                                title: theme_config('elfbar-whyus-1-title')|default('100% Originalware'),
                                text: theme_config('elfbar-whyus-1-text')|default('Direkt vom autorisierten Distributor – keine Grauimporte, keine Fälschungen.'),
                                items: [theme_config('elfbar-whyus-1-item-1')|default('Jede Charge geprüft & zertifiziert'), theme_config('elfbar-whyus-1-item-2')|default('Deutsche Steuerbanderole'), theme_config('elfbar-whyus-1-item-3')|default('Rechtssicher für den Wiederverkauf')]
                            },
                            {
                                icon: theme_config('elfbar-whyus-2-icon')|default('truck'),
                                title: theme_config('elfbar-whyus-2-title')|default('Schnell & zuverlässig'),
                                text: theme_config('elfbar-whyus-2-text')|default('Heute bestellt, in 24–48 h geliefert – planbar für Ihren Nachschub.'),
                                items: [theme_config('elfbar-whyus-2-item-1')|default('Versand aus deutschem Lager'), theme_config('elfbar-whyus-2-item-2')|default('Versandkostenfrei ab Mindestbestellwert'), theme_config('elfbar-whyus-2-item-3')|default('Sendungsverfolgung inklusive')]
                            },
                            {
                                icon: theme_config('elfbar-whyus-3-icon')|default('headset'),
                                title: theme_config('elfbar-whyus-3-title')|default('Persönlicher B2B-Service'),
                                text: theme_config('elfbar-whyus-3-text')|default('Ein fester Ansprechpartner, faire Konditionen und flexible Zahlung.'),
                                items: [theme_config('elfbar-whyus-3-item-1')|default('Kauf auf Rechnung für Gewerbekunden'), theme_config('elfbar-whyus-3-item-2')|default('Staffelpreise & Mengenrabatte'), theme_config('elfbar-whyus-3-item-3')|default('Beratung zu Sortiment & Aktionen')]
                            }
                        ] %}
                        <section class="elfbar-whyus" aria-labelledby="elfbar-whyus-title">
                            <header class="elfbar-whyus__head">
                                {% if theme_config('elfbar-whyus-eyebrow')|default('Ihre Vorteile') %}<p class="elfbar-whyus__eyebrow">{{ theme_config('elfbar-whyus-eyebrow')|default('Ihre Vorteile') }}</p>{% endif %}
                                <h2 class="elfbar-whyus__title" id="elfbar-whyus-title">{{ theme_config('elfbar-whyus-title')|default('Ihr zuverlässiger Großhandelspartner') }}</h2>
                                {% if theme_config('elfbar-whyus-sub')|default('Vom Bestellprozess bis zur Lieferung – wir machen Großhandel einfach, sicher und planbar. Das erwartet Sie als Partner:') %}<p class="elfbar-whyus__sub">{{ theme_config('elfbar-whyus-sub')|default('Vom Bestellprozess bis zur Lieferung – wir machen Großhandel einfach, sicher und planbar. Das erwartet Sie als Partner:') }}</p>{% endif %}
                            </header>
                            <div class="elfbar-whyus__grid">
                                {% for c in wuCards %}
                                    {% if c.title %}
                                    <article class="elfbar-whycard">
                                        <span class="elfbar-whycard__icon">{% sw_icon c.icon %}</span>
                                        <h3 class="elfbar-whycard__title">{{ c.title }}</h3>
                                        {% if c.text %}<p class="elfbar-whycard__text">{{ c.text }}</p>{% endif %}
                                        <ul class="elfbar-whycard__list">
                                            {% for it in c.items|filter(it => it) %}
                                                <li><span class="elfbar-whycard__chk"><svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></span> {{ it }}</li>
                                            {% endfor %}
                                        </ul>
                                    </article>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </section>
                    {% endblock %}
                    </div>
                    {% endif %}

                    {# ============ VERKAUFSVITRINE PRO — kompakt ============ #}
                    {% if theme_config('elfbar-sec-vitrine-enabled') is not same as(false) %}
                    <div class="elfbar-sec" style="order: {{ theme_config('elfbar-sec-vitrine-order')|default(elfbarSecOrderDefaults.vitrine) }}">
                    {% block elfbar_home_vitrine %}
                        {# Vitrine PRO — tüm içerik panelden (theme_config). Görsel doluysa
                           SVG çizim yerine gerçek foto gösterilir. #}
                        {% set vpBadge   = theme_config('elfbar-vitrine-badge')|default('Neu · Exklusiv für Händler') %}
                        {% set vpEyebrow = theme_config('elfbar-vitrine-eyebrow')|default('VITRINE PRO') %}
                        {% set vpTitle   = theme_config('elfbar-vitrine-title')|default('Premium Verkaufsvitrine für Ihren Store') %}
                        {% set vpText    = theme_config('elfbar-vitrine-text') %}
                        {% set vpImg     = theme_config('elfbar-vitrine-img') %}
                        {% set vpF1      = theme_config('elfbar-vitrine-feature-1') %}
                        {% set vpF2      = theme_config('elfbar-vitrine-feature-2') %}
                        {% set vpF3      = theme_config('elfbar-vitrine-feature-3') %}
                        {% set vpF4      = theme_config('elfbar-vitrine-feature-4') %}
                        {% set vpB1T     = theme_config('elfbar-vitrine-btn1-text') %}
                        {% set vpB1L     = theme_config('elfbar-vitrine-btn1-link') %}
                        {% set vpB2T     = theme_config('elfbar-vitrine-btn2-text') %}
                        {% set vpB2L     = theme_config('elfbar-vitrine-btn2-link') %}
                        <section class="elfbar-vitrine elfbar-vitrine--compact" aria-labelledby="elfbar-vitrine-title">
                            <div class="elfbar-vitrine__glow elfbar-vitrine__glow--a" aria-hidden="true"></div>
                            <div class="elfbar-vitrine__media">
                                {% if vpBadge %}<span class="elfbar-vitrine__badge">{{ vpBadge }}</span>{% endif %}
                                {% if vpImg %}
                                    <div class="elfbar-vitrine__photo"><img src="{{ vpImg }}" alt="{{ vpTitle }}" loading="lazy"></div>
                                {% else %}
                                <div class="elfbar-vitrine__cabinet" aria-hidden="true">
                                    <svg viewBox="0 0 200 280" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Verkaufsvitrine">
                                        <rect x="22" y="14" width="156" height="252" rx="10" fill="rgba(255,255,255,0.06)" stroke="rgba(255,255,255,0.22)" stroke-width="1.5"/>
                                        <rect x="22" y="14" width="156" height="46" rx="10" fill="url(#elfbar-vitrine-grad)"/>
                                        <text x="100" y="44" text-anchor="middle" font-family="'Space Grotesk',sans-serif" font-size="20" font-weight="700" fill="#fff" letter-spacing="2">ELFBAR</text>
                                        {% for row in 0..3 %}
                                            <line x1="30" y1="{{ 78 + row * 46 }}" x2="170" y2="{{ 78 + row * 46 }}" stroke="rgba(255,255,255,0.18)" stroke-width="1"/>
                                            {% for col in 0..3 %}
                                                <rect x="{{ 36 + col * 33 }}" y="{{ 84 + row * 46 }}" width="20" height="34" rx="4" fill="url(#elfbar-vitrine-prod)" opacity="0.92"/>
                                            {% endfor %}
                                        {% endfor %}
                                        <defs>
                                            <linearGradient id="elfbar-vitrine-grad" x1="22" y1="14" x2="178" y2="60" gradientUnits="userSpaceOnUse">
                                                <stop stop-color="#ff5ea7"/><stop offset="0.5" stop-color="#c85aff"/><stop offset="1" stop-color="#5a74ff"/>
                                            </linearGradient>
                                            <linearGradient id="elfbar-vitrine-prod" x1="0" y1="0" x2="0" y2="1">
                                                <stop stop-color="#ffb3d4"/><stop offset="1" stop-color="#8a9bff"/>
                                            </linearGradient>
                                        </defs>
                                    </svg>
                                </div>
                                {% endif %}
                            </div>
                            <div class="elfbar-vitrine__content">
                                {% if vpEyebrow %}<p class="elfbar-vitrine__eyebrow">{{ vpEyebrow }}</p>{% endif %}
                                {% if vpTitle %}<h2 class="elfbar-vitrine__title" id="elfbar-vitrine-title">{{ vpTitle }}</h2>{% endif %}
                                {% if vpText %}<p class="elfbar-vitrine__text">{{ vpText }}</p>{% endif %}
                                {% if vpF1 or vpF2 or vpF3 or vpF4 %}
                                    <ul class="elfbar-vitrine__features">
                                        {% if vpF1 %}<li>{% sw_icon 'shield' %} {{ vpF1 }}</li>{% endif %}
                                        {% if vpF2 %}<li>{% sw_icon 'shield' %} {{ vpF2 }}</li>{% endif %}
                                        {% if vpF3 %}<li>{% sw_icon 'shield' %} {{ vpF3 }}</li>{% endif %}
                                        {% if vpF4 %}<li>{% sw_icon 'shield' %} {{ vpF4 }}</li>{% endif %}
                                    </ul>
                                {% endif %}
                                {% if vpB1T or vpB2T %}
                                    <div class="elfbar-vitrine__actions">
                                        {% if vpB1T %}<a href="{{ vpB1L ?: path('frontend.account.register.page') }}" class="elfbar-btn elfbar-btn--gradient">{{ vpB1T }} {% sw_icon 'arrow-right' %}</a>{% endif %}
                                        {% if vpB2T %}<a href="{{ vpB2L ?: '#' }}" class="elfbar-btn elfbar-btn--outline">{{ vpB2T }}</a>{% endif %}
                                    </div>
                                {% endif %}
                            </div>
                        </section>
                    {% endblock %}
                    </div>
                    {% endif %}

                    {% if theme_config('elfbar-sec-campaign-enabled') is not same as(false) %}
                    <div class="elfbar-sec" style="order: {{ theme_config('elfbar-sec-campaign-order')|default(elfbarSecOrderDefaults.campaign) }}">
                    {% block elfbar_home_campaign %}
                        {# Marke veya Text boşsa tüm Banner gizli #}
                        {% if theme_config('elfbar-campaign-brand') or theme_config('elfbar-campaign-text') %}
                            <a href="{{ theme_config('elfbar-campaign-link') ?: '#' }}" class="elfbar-campaign">
                                {% if theme_config('elfbar-campaign-brand') %}<span class="elfbar-campaign__brand">{{ theme_config('elfbar-campaign-brand') }}</span>{% endif %}
                                {% if theme_config('elfbar-campaign-text') %}<span class="elfbar-campaign__text">{{ theme_config('elfbar-campaign-text') }}</span>{% endif %}
                            </a>
                        {% endif %}
                    {% endblock %}
                    </div>
                    {% endif %}

                    {# ============ TOP-BANNER (tam genişlik, promo görsellerin ÜSTÜNDE).
                       col-12, height = promo görselleriyle aynı (aspect 16/3). Görsel
                       boşsa gizli. Panelden: img / img-mobile / link. ============ #}
                    {% if theme_config('elfbar-sec-topbanner-enabled') is not same as(false) %}
                    <div class="elfbar-sec" style="order: {{ theme_config('elfbar-sec-topbanner-order')|default(25) }}">
                    {% block elfbar_home_topbanner %}
                        {% set tbImg    = theme_config('elfbar-topbanner-img') %}
                        {% set tbImgMob = theme_config('elfbar-topbanner-img-mobile') %}
                        {% set tbLink   = theme_config('elfbar-topbanner-link') %}
                        {% if tbImg or tbImgMob %}
                            {% set tbTag = tbLink ? 'a' : 'div' %}
                            <{{ tbTag }} class="elfbar-topbanner{% if tbImgMob %} has-mobile{% endif %}"{% if tbLink %} href="{{ tbLink }}"{% endif %}>
                                {% if tbImg %}<img class="elfbar-topbanner__img elfbar-topbanner__img--desktop" src="{{ tbImg }}" alt="" loading="lazy">{% endif %}
                                {% if tbImgMob %}<img class="elfbar-topbanner__img elfbar-topbanner__img--mobile" src="{{ tbImgMob }}" alt="" loading="lazy">{% endif %}
                            </{{ tbTag }}>
                        {% else %}
                            {# Görsel yoksa placeholder (promo ile aynı görünüm) #}
                            <div class="elfbar-topbanner elfbar-topbanner--empty">{{ mediaSvg }}</div>
                        {% endif %}
                    {% endblock %}
                    </div>
                    {% endif %}

                    {% if theme_config('elfbar-sec-promo-enabled') is not same as(false) %}
                    <div class="elfbar-sec" style="order: {{ theme_config('elfbar-sec-promo-order')|default(elfbarSecOrderDefaults.promo) }}">
                    {% block elfbar_home_promo_imgs %}
                        <div class="elfbar-promo-imgs">
                            {% set promo1Link = theme_config('elfbar-promo-img-1-link') %}
                            {% set promo2Link = theme_config('elfbar-promo-img-2-link') %}
                            {% set promo1Tag = promo1Link ? 'a' : 'div' %}
                            {% set promo2Tag = promo2Link ? 'a' : 'div' %}
                            <{{ promo1Tag }}{% if promo1Link %} href="{{ promo1Link }}"{% endif %} class="elfbar-promo-img">{% if theme_config('elfbar-promo-img-1') %}<img src="{{ theme_config('elfbar-promo-img-1') }}" alt="" loading="lazy">{% else %}{{ mediaSvg }}{% endif %}</{{ promo1Tag }}>
                            <{{ promo2Tag }}{% if promo2Link %} href="{{ promo2Link }}"{% endif %} class="elfbar-promo-img">{% if theme_config('elfbar-promo-img-2') %}<img src="{{ theme_config('elfbar-promo-img-2') }}" alt="" loading="lazy">{% else %}{{ mediaSvg }}{% endif %}</{{ promo2Tag }}>
                        </div>
                    {% endblock %}
                    </div>
                    {% endif %}

                    {% if theme_config('elfbar-sec-deals-enabled') is not same as(false) %}
                    <div class="elfbar-sec" style="order: {{ theme_config('elfbar-sec-deals-order')|default(elfbarSecOrderDefaults.deals) }}">
                    {% block elfbar_home_deals %}
                        {% set dealTextColor = theme_config('elfbar-deal-text-color') %}
                        <div class="elfbar-section-head">
                            <div class="elfbar-section-head__titles">
                                {% if theme_config('elfbar-deals-title') %}<h2 class="elfbar-section-head__title">{{ theme_config('elfbar-deals-title') }}</h2>{% endif %}
                                {% if theme_config('elfbar-deals-sub') %}<p class="elfbar-section-head__sub">{{ theme_config('elfbar-deals-sub') }}</p>{% endif %}
                            </div>
                        </div>
                        <div class="elfbar-deals-row">
                            {# 3 Deal config'ten: name/brand/price/img/link/hours. İsim boşsa gizli. #}
                            {% for i in 1..2 %}
                                {% set dName = theme_config('elfbar-deal-' ~ i ~ '-name') %}
                                {% set dBrand = theme_config('elfbar-deal-' ~ i ~ '-brand') %}
                                {% set dPrice = theme_config('elfbar-deal-' ~ i ~ '-price') %}
                                {% set dImg = theme_config('elfbar-deal-' ~ i ~ '-img') %}
                                {% set dLink = theme_config('elfbar-deal-' ~ i ~ '-link') %}
                                {% set dHours = theme_config('elfbar-deal-' ~ i ~ '-hours')|default(12 + i * 6) %}
                                {% if dName %}
                                <div class="elfbar-deal" data-elfbar-countdown data-end-hours="{{ dHours }}">
                                    {# Flip-clock geri sayım #}
                                    <div class="elfbar-deal__timer">
                                        <span class="elfbar-deal__t"><b data-d>05</b><small>Tage</small></span>
                                        <span class="elfbar-deal__t"><b data-h>14</b><small>Stunden</small></span>
                                        <span class="elfbar-deal__t"><b data-m>26</b><small>Minuten</small></span>
                                        <span class="elfbar-deal__t"><b data-s>24</b><small>Sekunden</small></span>
                                    </div>
                                    {# Beyaz iç ürün kartı #}
                                    <div class="elfbar-deal__card">
                                        <div class="elfbar-deal__img">{% if dImg %}<img src="{{ dImg }}" alt="{{ dName }}" loading="lazy">{% else %}{{ mediaSvg }}{% endif %}</div>
                                        <div class="elfbar-deal__brand"{% if dealTextColor %} style="background:{{ dealTextColor }}"{% endif %}>{{ dBrand }}</div>
                                        <div class="elfbar-deal__name"{% if dealTextColor %} style="color:{{ dealTextColor }}"{% endif %}>{{ dName }}</div>
                                        {# Deal-Karte = reine Panel-Texte (kein echtes Produkt) → KEINE Fake-Sterne/Reviews.
                                           Bewertungen nur dort, wo echte Shopware-Daten existieren (Produktdetail/Listing). #}
                                        <div class="elfbar-deal__foot">
                                            {% if elfbarLoggedIn %}
                                                <span class="elfbar-deal__price">{{ dPrice }}</span>
                                                <a href="{{ dLink ?: '#' }}" class="elfbar-deal__btn">
                                                    {% sw_icon 'bag-product' %} Kaufen
                                                </a>
                                            {% else %}
                                                <span class="elfbar-deal__price is-login">{% sw_icon 'lock-closed' %} Login</span>
                                                <a href="{{ path('frontend.account.login.page') }}" class="elfbar-deal__btn">Anmelden</a>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    {% endblock %}
                    </div>
                    {% endif %}

                    {# ============ Geniş banner (Deals ↔ Neuheiten arası,
                       ~1292×239) — panelden görsel+link, görsel boşsa gizli ============ #}
                    {% if theme_config('elfbar-sec-banner-enabled') is not same as(false) %}
                    <div class="elfbar-sec" style="order: {{ theme_config('elfbar-sec-banner-order')|default(elfbarSecOrderDefaults.banner) }}">
                    {% block elfbar_home_banner %}
                        {% set vbImg    = theme_config('elfbar-home-banner-img') %}
                        {% set vbImgMob = theme_config('elfbar-home-banner-img-mobile') %}
                        {% set vbLink   = theme_config('elfbar-home-banner-link') %}
                        {% if vbImg or vbImgMob %}
                            {% set vbTag = vbLink ? 'a' : 'div' %}
                            <{{ vbTag }} class="elfbar-home-banner{% if vbImgMob %} has-mobile{% endif %}"{% if vbLink %} href="{{ vbLink }}"{% endif %}>
                                {% if vbImg %}<img class="elfbar-home-banner__img elfbar-home-banner__img--desktop" src="{{ vbImg }}" alt="" loading="lazy">{% endif %}
                                {% if vbImgMob %}<img class="elfbar-home-banner__img elfbar-home-banner__img--mobile" src="{{ vbImgMob }}" alt="" loading="lazy">{% endif %}
                            </{{ vbTag }}>
                        {% endif %}
                    {% endblock %}
                    </div>
                    {% endif %}

                    {# ============ Neuheiten — yatay slider kart ============ #}
                    {% if theme_config('elfbar-sec-neu-enabled') is not same as(false) %}
                    <div class="elfbar-sec" style="order: {{ theme_config('elfbar-sec-neu-order')|default(elfbarSecOrderDefaults.neu) }}">
                    {% block elfbar_home_neu %}
                        <div class="elfbar-section-head">
                            <div class="elfbar-section-head__titles">
                                {% if theme_config('elfbar-neu-title') %}<h2 class="elfbar-section-head__title">{{ theme_config('elfbar-neu-title') }}</h2>{% endif %}
                                {% if theme_config('elfbar-neu-sub') %}<p class="elfbar-section-head__sub">{{ theme_config('elfbar-neu-sub') }}</p>{% endif %}
                            </div>
                            <div class="elfbar-slider-nav">
                                <button type="button" class="elfbar-slider-btn" data-slide="prev" aria-label="Zurück"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 6 9 12 15 18"/></svg></button>
                                <button type="button" class="elfbar-slider-btn" data-slide="next" aria-label="Weiter"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg></button>
                            </div>
                        </div>
                        {% set elfbarNeu = page.extensions.elfbarNeu.products ?? [] %}
                        <div class="elfbar-cardslider" data-elfbar-cardslider>
                            <div class="elfbar-cardslider__track">
                                {% for product in elfbarNeu %}
                                    {{ _self.elfbarProductCard(product, elfbarLoggedIn, 'Neu') }}
                                {% endfor %}
                            </div>
                        </div>
                    {% endblock %}
                    </div>
                    {% endif %}

                    {# Vitrine-Banner (Showcase) KALDIRILDI — kullanılmıyordu. #}

                    {# ============ Bestseller-Grid ============ #}
                    {% if theme_config('elfbar-sec-bestseller-enabled') is not same as(false) %}
                    <div class="elfbar-sec" style="order: {{ theme_config('elfbar-sec-bestseller-order')|default(elfbarSecOrderDefaults.bestseller) }}">
                    {% block elfbar_home_section_title %}
                        {% set elfbarBest = page.extensions.elfbarBestseller.products ?? [] %}
                        <div class="elfbar-section-head">
                            <div class="elfbar-section-head__titles">
                                {% if theme_config('elfbar-bestseller-title') %}<h2 class="elfbar-section-head__title">{{ theme_config('elfbar-bestseller-title') }}</h2>{% endif %}
                                {% if theme_config('elfbar-bestseller-sub') %}<p class="elfbar-section-head__sub">{{ theme_config('elfbar-bestseller-sub') }}</p>{% endif %}
                            </div>
                            <a href="{{ path('frontend.navigation.page', { navigationId: context.salesChannel.navigationCategoryId }) }}" class="elfbar-section-head__link">Alle anzeigen →</a>
                        </div>
                        {% if elfbarBest|length %}
                            <div class="elfbar-cardgrid">
                                {% for product in elfbarBest %}
                                    {{ _self.elfbarProductCard(product, elfbarLoggedIn, 'Bestseller') }}
                                {% endfor %}
                            </div>
                        {% else %}
                            {# Fallback: henüz ürün yok (kategori/ürün eklenince dolacak) #}
                            <div class="elfbar-body__cms elfbar-body__cms--empty">
                                <p>Bald verfügbar – Produkte werden in Kürze ergänzt.</p>
                            </div>
                        {% endif %}
                    {% endblock %}
                    </div>
                    {% endif %}

                    {# ============ B2B avantaj / kayıt CTA banner ============ #}
                    {% if theme_config('elfbar-sec-b2b-enabled') is not same as(false) %}
                    <div class="elfbar-sec" style="order: {{ theme_config('elfbar-sec-b2b-order')|default(elfbarSecOrderDefaults.b2b) }}">
                    {% block elfbar_home_b2b_cta %}
                        {# Statları topla (sayı boş olanı atla) #}
                        {% set elfbarB2bStats = [] %}
                        {% for s in [
                            {n: theme_config('elfbar-b2b-stat-1-n'), l: theme_config('elfbar-b2b-stat-1-l')},
                            {n: theme_config('elfbar-b2b-stat-2-n'), l: theme_config('elfbar-b2b-stat-2-l')},
                            {n: theme_config('elfbar-b2b-stat-3-n'), l: theme_config('elfbar-b2b-stat-3-l')},
                            {n: theme_config('elfbar-b2b-stat-4-n'), l: theme_config('elfbar-b2b-stat-4-l')}
                        ] %}
                            {% if s.n %}{% set elfbarB2bStats = elfbarB2bStats|merge([s]) %}{% endif %}
                        {% endfor %}
                        {% set elfbarB2bHasContent = theme_config('elfbar-b2b-eyebrow') or theme_config('elfbar-b2b-title') or theme_config('elfbar-b2b-text') or theme_config('elfbar-b2b-btn-primary') or theme_config('elfbar-b2b-btn-ghost') %}

                        {# Tüm B2B banner boşsa (içerik + stat yok) hiç gösterme #}
                        {% if elfbarB2bHasContent or elfbarB2bStats|length %}
                            <section class="elfbar-b2b">
                                <div class="elfbar-b2b__content">
                                    {% if theme_config('elfbar-b2b-eyebrow') %}<span class="elfbar-b2b__eyebrow">{{ theme_config('elfbar-b2b-eyebrow') }}</span>{% endif %}
                                    {% if theme_config('elfbar-b2b-title') %}<h2 class="elfbar-b2b__title">{{ theme_config('elfbar-b2b-title')|raw }}</h2>{% endif %}
                                    {% if theme_config('elfbar-b2b-text') %}<p class="elfbar-b2b__text">{{ theme_config('elfbar-b2b-text') }}</p>{% endif %}
                                    {% if theme_config('elfbar-b2b-btn-primary') or theme_config('elfbar-b2b-btn-ghost') %}
                                        <div class="elfbar-b2b__actions">
                                            {% if theme_config('elfbar-b2b-btn-primary') %}<a href="{{ path('frontend.account.register.page') }}" class="elfbar-b2b__btn is-primary">{{ theme_config('elfbar-b2b-btn-primary') }}</a>{% endif %}
                                            {% if theme_config('elfbar-b2b-btn-ghost') %}<a href="{{ path('frontend.account.login.page') }}" class="elfbar-b2b__btn is-ghost">{{ theme_config('elfbar-b2b-btn-ghost') }}</a>{% endif %}
                                        </div>
                                    {% endif %}
                                </div>
                                {% if elfbarB2bStats|length %}
                                    <div class="elfbar-b2b__stats">
                                        {% for s in elfbarB2bStats %}
                                            <div class="elfbar-b2b__stat"><b>{{ s.n }}</b>{% if s.l %}<small>{{ s.l }}</small>{% endif %}</div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </section>
                        {% endif %}
                    {% endblock %}
                    </div>
                    {% endif %}

                    {# ============ Premium B2B section akışı — her alt-section kendi
                       elfbar-sec wrapper'ında (panelden aç/kapa + sıra) ============ #}
                    {% block elfbar_home_premium_sections %}
                        {% set elfbarBest = page.extensions.elfbarBestseller.products ?? [] %}
                        {% set elfbarNeu  = page.extensions.elfbarNeu.products ?? [] %}

                        {# Kategori-Slider 1: Bestseller (sol görsel + sağ ürün slider) #}
                        {% if elfbarBest|length and theme_config('elfbar-sec-catslider1-enabled') is not same as(false) %}
                            <div class="elfbar-sec" style="order: {{ theme_config('elfbar-sec-catslider1-order')|default(elfbarSecOrderDefaults.catslider1) }}">
                            {{ _self.elfbarCatSlider(elfbarBest, elfbarLoggedIn, 'Top', 'pink',
                                theme_config('elfbar-catslider1-title')|default('Bestseller'),
                                theme_config('elfbar-catslider1-sub')|default('Die meistverkauften Produkte unserer Händler.'),
                                path('frontend.navigation.page', { navigationId: context.salesChannel.navigationCategoryId }),
                                theme_config('elfbar-catslider1-eyebrow')|default('Kategorie'),
                                theme_config('elfbar-catslider1-img')) }}
                            </div>
                        {% endif %}

                        {# USP (panel: usp) — Markenwelt zaten kaldırılmış #}
                        {% if theme_config('elfbar-sec-usp-enabled') is not same as(false) %}
                            <div class="elfbar-sec" style="order: {{ theme_config('elfbar-sec-usp-order')|default(elfbarSecOrderDefaults.usp) }}">
                            {% sw_include '@ElfbarTheme/storefront/page/content/_home-sections-top.html.twig' %}
                            </div>
                        {% endif %}

                        {# Kategori-Slider 2: Neuheiten (sol görsel + sağ ürün slider) #}
                        {% if elfbarNeu|length and theme_config('elfbar-sec-catslider2-enabled') is not same as(false) %}
                            <div class="elfbar-sec" style="order: {{ theme_config('elfbar-sec-catslider2-order')|default(elfbarSecOrderDefaults.catslider2) }}">
                            {{ _self.elfbarCatSlider(elfbarNeu, elfbarLoggedIn, 'Neu', 'blue',
                                theme_config('elfbar-catslider2-title')|default('Neuheiten'),
                                theme_config('elfbar-catslider2-sub')|default('Frisch im Sortiment – jetzt als Erster bestellen.'),
                                path('frontend.navigation.page', { navigationId: context.salesChannel.navigationCategoryId }),
                                theme_config('elfbar-catslider2-eyebrow')|default('Kategorie'),
                                theme_config('elfbar-catslider2-img')) }}
                            </div>
                        {% endif %}

                        {# İnce şerit banner 2: VITRINE PRO tanıtımı (dev banner yerine) #}
                        {% if theme_config('elfbar-sec-stripe2-enabled') is not same as(false) %}
                        <div class="elfbar-sec" style="order: {{ theme_config('elfbar-sec-stripe2-order')|default(elfbarSecOrderDefaults.stripe2) }}">
                        {% block elfbar_home_stripe2 %}
                            <a href="{{ path('frontend.account.register.page') }}" class="elfbar-stripe elfbar-stripe--dark">
                                <span class="elfbar-stripe__ico">{% sw_icon 'products' %}</span>
                                <span class="elfbar-stripe__txt"><b>VITRINE PRO</b> · Premium Verkaufsvitrine – für Bestandskunden auf Wunsch kostenlos</span>
                                <span class="elfbar-stripe__cta">Anfragen {% sw_icon 'arrow-right' %}</span>
                            </a>
                        {% endblock %}
                        </div>
                        {% endif %}

                        {# HowTo + FAQ (panel: howtofaq) #}
                        {% if theme_config('elfbar-sec-howtofaq-enabled') is not same as(false) %}
                            <div class="elfbar-sec" style="order: {{ theme_config('elfbar-sec-howtofaq-order')|default(elfbarSecOrderDefaults.howtofaq) }}">
                            {% sw_include '@ElfbarTheme/storefront/page/content/_home-sections-bottom.html.twig' with { elfbarShowHowto: true, elfbarShowReviews: false } %}
                            </div>
                        {% endif %}

                        {# Bewertungen-Slider (panel: reviews) #}
                        {% if theme_config('elfbar-sec-reviews-enabled') is not same as(false) %}
                            <div class="elfbar-sec" style="order: {{ theme_config('elfbar-sec-reviews-order')|default(elfbarSecOrderDefaults.reviews) }}">
                            {% sw_include '@ElfbarTheme/storefront/page/content/_home-sections-bottom.html.twig' with { elfbarShowHowto: false, elfbarShowReviews: true } %}
                            </div>
                        {% endif %}
                    {% endblock %}

                    {# ============ SERBEST BÖLÜMLER (panelden eklenen kendi blokların).
                       Ekip yeni bölüm eklemek istediğinde: panelde "98) Freie Sektionen"
                       altında boş bir slotun Typ'ını seçer, içeriğini doldurur, sıra verir.
                       Aynı elfbar-sec + CSS order mekanizması → standart section'larla
                       iç içe sıralanır. type='none' → hiç render edilmez. ============ #}
                    {% block elfbar_home_free_sections %}
                        {% for i in 1..6 %}
                            {% set fp = 'elfbar-free-' ~ i %}
                            {% set fType  = theme_config(fp ~ '-type')|default('none') %}
                            {% if fType and fType != 'none' %}
                                {% set fOrder = theme_config(fp ~ '-order')|default(200 + i * 10) %}
                                {% set fTitle = theme_config(fp ~ '-title') %}
                                {% set fText  = theme_config(fp ~ '-text') %}
                                {% set fImg   = theme_config(fp ~ '-img') %}
                                {% set fImg2  = theme_config(fp ~ '-img2') %}
                                {% set fImgM  = theme_config(fp ~ '-img-mobile') %}
                                {% set fLink  = theme_config(fp ~ '-link') %}
                                {% set fBtnT  = theme_config(fp ~ '-btn-text') %}
                                {% set fBtnL  = theme_config(fp ~ '-btn-link') %}
                                <div class="elfbar-sec" style="order: {{ fOrder }}">
                                    {% if fType == 'banner' %}
                                        {% if fImg or fImgM %}
                                            {% set bTag = fLink ? 'a' : 'div' %}
                                            <{{ bTag }} class="elfbar-free elfbar-free--banner{% if fImgM %} has-mobile{% endif %}"{% if fLink %} href="{{ fLink }}"{% endif %}>
                                                {% if fImg %}<img class="elfbar-free__img elfbar-free__img--desktop" src="{{ fImg }}" alt="{{ fTitle }}" loading="lazy">{% endif %}
                                                {% if fImgM %}<img class="elfbar-free__img elfbar-free__img--mobile" src="{{ fImgM }}" alt="{{ fTitle }}" loading="lazy">{% endif %}
                                            </{{ bTag }}>
                                        {% endif %}
                                    {% elseif fType == 'titletext' %}
                                        {% if fTitle or fText %}
                                            <section class="elfbar-free elfbar-free--titletext">
                                                {% if fTitle %}<h2 class="elfbar-free__title">{{ fTitle }}</h2>{% endif %}
                                                {% if fText %}<p class="elfbar-free__text">{{ fText }}</p>{% endif %}
                                            </section>
                                        {% endif %}
                                    {% elseif fType == 'cta' %}
                                        {% if fTitle or fText or fBtnT %}
                                            <section class="elfbar-free elfbar-free--cta">
                                                <div class="elfbar-free__cta-body">
                                                    {% if fTitle %}<h2 class="elfbar-free__title">{{ fTitle }}</h2>{% endif %}
                                                    {% if fText %}<p class="elfbar-free__text">{{ fText }}</p>{% endif %}
                                                    {% if fBtnT %}<a href="{{ fBtnL ?: '#' }}" class="elfbar-btn elfbar-btn--gradient elfbar-free__btn">{{ fBtnT }} {% sw_icon 'arrow-right' %}</a>{% endif %}
                                                </div>
                                            </section>
                                        {% endif %}
                                    {% elseif fType == 'twoimg' %}
                                        {% if fImg or fImg2 %}
                                            <div class="elfbar-free elfbar-free--twoimg">
                                                {% set t1 = fLink ? 'a' : 'div' %}
                                                <{{ t1 }} class="elfbar-free__cell"{% if fLink %} href="{{ fLink }}"{% endif %}>{% if fImg %}<img src="{{ fImg }}" alt="{{ fTitle }}" loading="lazy">{% endif %}</{{ t1 }}>
                                                <div class="elfbar-free__cell">{% if fImg2 %}<img src="{{ fImg2 }}" alt="{{ fTitle }}" loading="lazy">{% endif %}</div>
                                            </div>
                                        {% endif %}
                                    {% elseif fType == 'stripe' %}
                                        {% if fTitle or fText or fBtnT %}
                                            {% set sTag = fBtnL ? 'a' : (fLink ? 'a' : 'div') %}
                                            {% set sHref = fBtnL ?: fLink %}
                                            <{{ sTag }} class="elfbar-free elfbar-free--stripe"{% if sHref %} href="{{ sHref }}"{% endif %}>
                                                <span class="elfbar-free__stripe-ico">{% sw_icon 'products' %}</span>
                                                <span class="elfbar-free__stripe-txt">{% if fTitle %}<b>{{ fTitle }}</b>{% endif %}{% if fText %} · {{ fText }}{% endif %}</span>
                                                {% if fBtnT %}<span class="elfbar-free__stripe-cta">{{ fBtnT }} {% sw_icon 'arrow-right' %}</span>{% endif %}
                                            </{{ sTag }}>
                                        {% endif %}
                                    {% endif %}
                                </div>
                            {% endif %}
                        {% endfor %}
                    {% endblock %}
                </div>
            </div>
        </div>
    {% elseif (page.landingPage ? page.landingPage.cmsPage.type : page.cmsPage.type)|default('') != 'product_list' %}
        {# ============ İÇERİK SAYFASI (AGB/Datenschutz/Impressum/Widerruf vb.) —
           ürün listesi DEĞİL (cmsPage.type != product_list). Kategori ağacı/filtre YOK.
           Temiz, ortalanmış, okunur tipografi. ============ #}
        {% set elfbarCmsPage = page.landingPage ? page.landingPage.cmsPage : page.cmsPage %}
        {% set elfbarContentTitle = page.header.navigation.active.translated.name
            |default(page.landingPage.translated.name)
            |default(page.metaInformation.metaTitle)
            |default('') %}
        <div class="elfbar-content-page">
            <article class="elfbar-content-page__inner">
                {% if elfbarContentTitle %}
                    <header class="elfbar-content-page__head">
                        <h1 class="elfbar-content-page__title">{{ elfbarContentTitle }}</h1>
                    </header>
                {% endif %}
                <div class="elfbar-content-page__cms">
                    {{ parent() }}
                </div>
            </article>
        </div>
    {% else %}
        {# ============ KATEGORİ SAYFASI — 2 kolon (sol: kategori ağacı + filtreler | sağ: başlık + liste) ============ #}
        {# Dinamik kategori ağacı (subscriber → NavigationLoader). #}
        {% set elfbarNavTree = page.extensions.elfbarNavTree.tree|default([]) %}

        {# Sayfa başlığı: önce aktif navigasyon, yoksa dinamik ağaçtan eşleştir. #}
        {% set elfbarCatTitle = page.header.navigation.active.translated.name|default('') %}
        {% if elfbarCatTitle is empty %}
            {% for treeItem in elfbarNavTree %}
                {% if shopware.navigation.id == treeItem.category.id %}{% set elfbarCatTitle = treeItem.category.translated.name %}{% endif %}
            {% endfor %}
        {% endif %}

        <div class="elfbar-cat">
            {# --- SOL KOL: kategori paneli + filtreler tek sticky blok (desktop'ta birlikte kayar) ---
                 Mobilde aside ve filtersheet position:fixed bottom-sheet olur → sarmalayıcı etkisiz. #}
            <div class="elfbar-cat__col">
                {# --- kategori ağacı sidebar (mega menü) --- #}
                <aside class="elfbar-cat__aside" data-elfbar-sheet="cats">
                    <div class="elfbar-cat__aside-head">
                        Alle Kategorien
                        <button type="button" class="elfbar-sheet__close" data-elfbar-sheet-close aria-label="Schließen">✕</button>
                    </div>
                    {% sw_include '@Storefront/storefront/component/elfbar/megamenu.html.twig' with { elfbarNavTree: elfbarNavTree, activeId: shopware.navigation.id } %}
                </aside>

                {# --- Filtreler için ayrı BOTTOM-SHEET (data-elfbar-sheet="filter") --- #}
                <div class="elfbar-cat__filtersheet" data-elfbar-sheet="filter">
                    <div class="elfbar-cat__aside-head">
                        Filter
                        <button type="button" class="elfbar-sheet__close" data-elfbar-sheet-close aria-label="Schließen">✕</button>
                    </div>
                    {# Filtre paneli JS ile buraya taşınır (CSS desktop'ta sol kola koyar) #}
                    <div class="elfbar-cat__filterslot" data-elfbar-filter-slot></div>
                </div>
            </div>

            {# Bottom-sheet'ler için ortak backdrop #}
            <div class="elfbar-sheet__backdrop" data-elfbar-sheet-backdrop hidden></div>

            {# --- SAĞ: başlık + CMS içeriği (filtre paneli + ürün listesi) --- #}
            <div class="elfbar-cat__main">
                <h1 class="elfbar-cat__title">{{ elfbarCatTitle ?: page.header.navigation.active.translated.name|default(page.metaInformation.metaTitle|default('Produkte')) }}</h1>

                {# MOBİL: yan yana 2 buton — Kategorien + Filter (bottom-sheet açar) #}
                <div class="elfbar-cat__mobilebar">
                    <button type="button" class="elfbar-cat__mbtn" data-elfbar-sheet-open="cats">
                        {% sw_icon 'stack' %}<span>Kategorien</span>
                    </button>
                    <button type="button" class="elfbar-cat__mbtn" data-elfbar-sheet-open="filter">
                        {% sw_icon 'filter' %}<span>Filter</span>
                    </button>
                </div>

                <div class="elfbar-cat__cms">
                    {{ parent() }}
                </div>
            </div>
        </div>

        {# =====================================================================
           B2B CANLI SEPET BARI (sticky, ekran altı) — +/− satırlardan sepete
           anında yazar; bu bar GERÇEK sepet özetini gösterir. JS: initLiveCart.
           ===================================================================== #}
        <div class="elfbar-bulkbar" data-elfbar-cartbar hidden>
            <div class="elfbar-bulkbar__inner">
                <div class="elfbar-bulkbar__info">
                    <span class="elfbar-bulkbar__count"><b data-cart-products>0</b> Produkte</span>
                    <span class="elfbar-bulkbar__sep">·</span>
                    <span class="elfbar-bulkbar__qty"><b data-cart-units>0</b> Stück</span>
                    <span class="elfbar-bulkbar__total" data-cart-total></span>
                </div>
                <div class="elfbar-bulkbar__actions">
                    <a class="elfbar-bulkbar__clear" href="{{ path('frontend.checkout.cart.page') }}">Warenkorb ansehen</a>
                    <a class="elfbar-bulkbar__submit" href="{{ path('frontend.checkout.confirm.page') }}">
                        {% sw_icon 'bag-product' %} <span>Zur Kasse</span>
                    </a>
                </div>
            </div>
        </div>
    {% endif %}
{% endblock %}

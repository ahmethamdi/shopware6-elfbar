{# Premium section'lar — ÜST grup: USP grid + Markenwelt. Başlıklar SOLA yaslı (.elfbar-shead). #}

{# ---- WARUM ELFBAR B2B? — USP Grid ---- #}
<section class="elfbar-usps" aria-labelledby="elfbar-usps-title">
    <header class="elfbar-shead">
        <p class="elfbar-shead__eyebrow">Ihre Vorteile</p>
        <h2 class="elfbar-shead__title" id="elfbar-usps-title">Warum ELFBAR B2B?</h2>
        <p class="elfbar-shead__sub">Der Großhandel, der für Ihren Erfolg gemacht ist.</p>
    </header>
    <div class="elfbar-usps__grid">
        <article class="elfbar-usp-card">
            <span class="elfbar-usp-card__icon">{% sw_icon 'bag-product' %}</span>
            <h3 class="elfbar-usp-card__title">Top-Margen für Händler</h3>
            <p class="elfbar-usp-card__text">Attraktive Staffelpreise und Mengenrabatte sichern Ihnen erstklassige Gewinnspannen.</p>
        </article>
        <article class="elfbar-usp-card">
            <span class="elfbar-usp-card__icon">{% sw_icon 'truck' %}</span>
            <h3 class="elfbar-usp-card__title">Schnelle Lieferung 24–48h</h3>
            <p class="elfbar-usp-card__text">Bestellt am Nachmittag, geliefert übermorgen – versandkostenfrei ab Mindestbestellwert.</p>
        </article>
        <article class="elfbar-usp-card">
            <span class="elfbar-usp-card__icon">{% sw_icon 'lock-closed' %}</span>
            <h3 class="elfbar-usp-card__title">Kauf auf Rechnung &amp; PayPal</h3>
            <p class="elfbar-usp-card__text">Flexible Zahlung für Gewerbekunden – sicher, geprüft und ohne Vorkasse-Zwang.</p>
        </article>
        <article class="elfbar-usp-card">
            <span class="elfbar-usp-card__icon">{% sw_icon 'headset' %}</span>
            <h3 class="elfbar-usp-card__title">Persönlicher B2B-Support</h3>
            <p class="elfbar-usp-card__text">Ihr fester Ansprechpartner berät Sie zu Sortiment, Aktionen und Nachschub.</p>
        </article>
    </div>
</section>

{# UNSERE MARKENWELT section KALDIRILDI (kullanıcı isteği). #}

{# Premium section — "Unser Versprechen" (split banner: koyu sol + vaat listesi).
   Eski USP grid'in yerini aldı (whyus ile duplicate'ti). Tümü panelden editlenebilir. #}

{# ---- UNSER VERSPRECHEN — split banner ---- #}
{% set vpEyebrow = theme_config('elfbar-promise-eyebrow')|default('Unser Versprechen') %}
{% set vpTitle   = theme_config('elfbar-promise-title')|default('Mehr als nur ein Lieferant') %}
{% set vpText    = theme_config('elfbar-promise-text')|default('Wir denken wie ein Partner – mit Leistungen, die Ihren Alltag im Handel wirklich einfacher machen.') %}
{% set vpItems = [
    { t: theme_config('elfbar-promise-1-title')|default('Gratis Displaymaterial'), d: theme_config('elfbar-promise-1-text')|default('Aufsteller & Werbemittel für Ihren Verkaufsraum.') },
    { t: theme_config('elfbar-promise-2-title')|default('Frische-Garantie'), d: theme_config('elfbar-promise-2-text')|default('Kurze Lagerzeiten – immer aktuelle Chargen.') },
    { t: theme_config('elfbar-promise-3-title')|default('Faire Mengenstaffel'), d: theme_config('elfbar-promise-3-text')|default('Je mehr Sie bestellen, desto besser Ihr Preis.') }
]|filter(i => i.t) %}

<section class="elfbar-promise" aria-labelledby="elfbar-promise-title">
    <div class="elfbar-promise__left">
        {% if vpEyebrow %}<p class="elfbar-promise__eyebrow">{{ vpEyebrow }}</p>{% endif %}
        {% if vpTitle %}<h2 class="elfbar-promise__title" id="elfbar-promise-title">{{ vpTitle }}</h2>{% endif %}
        {% if vpText %}<p class="elfbar-promise__text">{{ vpText }}</p>{% endif %}
    </div>
    <div class="elfbar-promise__right">
        {% for it in vpItems %}
            <div class="elfbar-promise__item">
                <span class="elfbar-promise__check"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg></span>
                <div class="elfbar-promise__body">
                    <b>{{ it.t }}</b>
                    {% if it.d %}<span>{{ it.d }}</span>{% endif %}
                </div>
            </div>
        {% endfor %}
    </div>
</section>

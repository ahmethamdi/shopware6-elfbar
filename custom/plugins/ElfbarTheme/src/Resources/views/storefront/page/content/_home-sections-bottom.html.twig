{# Premium section'lar — ALT grup: HowTo + FAQ (2 kolon) + Reviews. Başlıklar SOLA yaslı.
   elfbarShowHowto / elfbarShowReviews flag'leriyle ayrı ayrı render edilebilir
   (panelden bağımsız aç/kapa + sıra). Flag verilmezse ikisi de gösterilir. #}
{% set elfbarShowHowto   = elfbarShowHowto is defined ? elfbarShowHowto : true %}
{% set elfbarShowReviews = elfbarShowReviews is defined ? elfbarShowReviews : true %}

{# ---- IN 3 SCHRITTEN ZUM HÄNDLER — Steps + FAQ ---- #}
{% if elfbarShowHowto %}
<section class="elfbar-howto" aria-labelledby="elfbar-howto-title">
    <header class="elfbar-shead">
        {% if theme_config('elfbar-howto-eyebrow') %}<p class="elfbar-shead__eyebrow">{{ theme_config('elfbar-howto-eyebrow') }}</p>{% endif %}
        {% if theme_config('elfbar-howto-title') %}<h2 class="elfbar-shead__title" id="elfbar-howto-title">{{ theme_config('elfbar-howto-title') }}</h2>{% endif %}
        {% if theme_config('elfbar-howto-sub') %}<p class="elfbar-shead__sub">{{ theme_config('elfbar-howto-sub') }}</p>{% endif %}
    </header>

    <ol class="elfbar-steps">
        <li class="elfbar-step">
            <span class="elfbar-step__num">1</span>
            <span class="elfbar-step__icon">{% sw_icon 'rocket' %}</span>
            <h3 class="elfbar-step__title">Registrieren</h3>
            <p class="elfbar-step__text">Gewerbedaten eingeben und Konto kostenlos erstellen.</p>
        </li>
        <li class="elfbar-step">
            <span class="elfbar-step__num">2</span>
            <span class="elfbar-step__icon">{% sw_icon 'lock-closed' %}</span>
            <h3 class="elfbar-step__title">Freischaltung</h3>
            <p class="elfbar-step__text">Wir prüfen Ihren Gewerbenachweis – meist innerhalb weniger Stunden.</p>
        </li>
        <li class="elfbar-step">
            <span class="elfbar-step__num">3</span>
            <span class="elfbar-step__icon">{% sw_icon 'bag-product' %}</span>
            <h3 class="elfbar-step__title">Bestellen</h3>
            <p class="elfbar-step__text">Großhandelspreise sehen, Sortiment wählen und losbestellen.</p>
        </li>
    </ol>

    <div class="elfbar-howto__cta">
        <a href="{{ path('frontend.account.register.page') }}" class="elfbar-btn elfbar-btn--gradient">
            Jetzt Händlerkonto erstellen {% sw_icon 'arrow-right' %}
        </a>
    </div>

    {% if theme_config('elfbar-faq-head') %}<h3 class="elfbar-faq__head">{{ theme_config('elfbar-faq-head') }}</h3>{% endif %}
    <div class="elfbar-faq elfbar-faq--grid">
        <div class="elfbar-faq__item">
            <button type="button" class="elfbar-faq__q">
                <span>Wer kann sich als Händler registrieren?</span>
                <span class="elfbar-faq__chev" aria-hidden="true">{% sw_icon 'arrow-right' %}</span>
            </button>
            <div class="elfbar-faq__a">
                <p>Die Registrierung ist ausschließlich Gewerbetreibenden mit gültigem Gewerbenachweis vorbehalten. Privatverkauf ist ausgeschlossen.</p>
            </div>
        </div>
        <div class="elfbar-faq__item">
            <button type="button" class="elfbar-faq__q">
                <span>Wie hoch ist der Mindestbestellwert?</span>
                <span class="elfbar-faq__chev" aria-hidden="true">{% sw_icon 'arrow-right' %}</span>
            </button>
            <div class="elfbar-faq__a">
                <p>Der Mindestbestellwert liegt bei 250 € netto. Ab 500 € netto liefern wir versandkostenfrei innerhalb Deutschlands.</p>
            </div>
        </div>
        <div class="elfbar-faq__item">
            <button type="button" class="elfbar-faq__q">
                <span>Welche Zahlungsarten stehen zur Verfügung?</span>
                <span class="elfbar-faq__chev" aria-hidden="true">{% sw_icon 'arrow-right' %}</span>
            </button>
            <div class="elfbar-faq__a">
                <p>Wir bieten Kauf auf Rechnung, PayPal, Kreditkarte und Vorkasse. Kauf auf Rechnung ist nach erfolgreicher Bonitätsprüfung verfügbar.</p>
            </div>
        </div>
        <div class="elfbar-faq__item">
            <button type="button" class="elfbar-faq__q">
                <span>Wie schnell wird geliefert?</span>
                <span class="elfbar-faq__chev" aria-hidden="true">{% sw_icon 'arrow-right' %}</span>
            </button>
            <div class="elfbar-faq__a">
                <p>Bestellungen, die werktags bis 14 Uhr eingehen, versenden wir noch am selben Tag. Die Zustellung erfolgt in der Regel innerhalb von 24–48 Stunden.</p>
            </div>
        </div>
    </div>
</section>
{% endif %}

{# ---- ÜBER 4.000 ZUFRIEDENE HÄNDLER — Reviews SLIDER (7-8 adet)
       (yıldız + metin; yazar/footer YOK) ---- #}
{% if elfbarShowReviews %}
<section class="elfbar-reviews" aria-labelledby="elfbar-reviews-title">
    <div class="elfbar-shead elfbar-reviews__head">
        <div>
            {% if theme_config('elfbar-reviews-eyebrow') %}<p class="elfbar-shead__eyebrow">{{ theme_config('elfbar-reviews-eyebrow') }}</p>{% endif %}
            {% if theme_config('elfbar-reviews-title') %}<h2 class="elfbar-shead__title" id="elfbar-reviews-title">{{ theme_config('elfbar-reviews-title') }}</h2>{% endif %}
            {% if theme_config('elfbar-reviews-sub') %}<p class="elfbar-shead__sub">{{ theme_config('elfbar-reviews-sub') }}</p>{% endif %}
        </div>
        <div class="elfbar-slider-nav">
            <button type="button" class="elfbar-slider-btn" data-slide="prev" aria-label="Zurück"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 6 9 12 15 18"/></svg></button>
            <button type="button" class="elfbar-slider-btn" data-slide="next" aria-label="Weiter"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg></button>
        </div>
    </div>

    {% set elfbar_reviews = [
        'Lieferung am nächsten Tag, top Margen und ein Ansprechpartner, der wirklich erreichbar ist. Genau so muss B2B sein.',
        'Die VITRINE PRO hat unseren Vape-Umsatz spürbar gesteigert. Kunden greifen einfach öfter zu. Klare Empfehlung.',
        'Riesige Auswahl, faire Staffelpreise und Kauf auf Rechnung ohne Stress. Wir bestellen seit über einem Jahr regelmäßig.',
        'Schnelle Abwicklung, faire Konditionen und immer top Ware. Der Bestellprozess könnte kaum einfacher sein.',
        'Die Liefergeschwindigkeit ist beeindruckend. Bestellt am Vormittag, geliefert am nächsten Werktag.',
        'Endlich ein Großhändler, der hält, was er verspricht. Sortiment, Preise und Service stimmen einfach.',
        'Die Staffelpreise machen den Unterschied. Wir konnten unsere Marge deutlich verbessern.',
        'Persönliche Beratung, schneller Versand und faire Preise – wir empfehlen ELFBAR B2B uneingeschränkt weiter.'
    ] %}
    <div class="elfbar-cardslider elfbar-reviews__slider" data-elfbar-cardslider>
        <div class="elfbar-cardslider__track">
            {% for text in elfbar_reviews %}
                <article class="elfbar-review-card">
                    <div class="elfbar-review-card__stars" aria-label="5 von 5 Sternen">
                        {# Dolu (filled) yıldız — sw_icon 'star' outline olduğu için inline SVG #}
                        {% for i in 1..5 %}<svg class="elfbar-star" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M12 2.5l2.9 6.06 6.6.72-4.9 4.48 1.32 6.5L12 17.9 6.08 20.76 7.4 14.26 2.5 9.78l6.6-.72L12 2.5z"/></svg>{% endfor %}
                    </div>
                    <p class="elfbar-review-card__text">{{ text }}</p>
                </article>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{# ============================================================
   ElfbarTheme — Anasayfa premium section'ları (B2B marka sitesi)
   index.html.twig home dalından sw_include ile çağrılır.
   ============================================================ #}

{# ============================================================
   1. VERKAUFSVITRINE PRO — Amiral Banner
   ============================================================ #}
<section class="elfbar-vitrine" aria-labelledby="elfbar-vitrine-title">
    <div class="elfbar-vitrine__glow elfbar-vitrine__glow--a" aria-hidden="true"></div>
    <div class="elfbar-vitrine__glow elfbar-vitrine__glow--b" aria-hidden="true"></div>

    <div class="elfbar-vitrine__media">
        <span class="elfbar-vitrine__badge">Neu · Exklusiv für Händler</span>
        <div class="elfbar-vitrine__cabinet" aria-hidden="true">
            <svg viewBox="0 0 200 280" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Verkaufsvitrine">
                <rect x="22" y="14" width="156" height="252" rx="10" fill="rgba(255,255,255,0.06)" stroke="rgba(255,255,255,0.22)" stroke-width="1.5"/>
                <rect x="22" y="14" width="156" height="46" rx="10" fill="url(#elfbar-vitrine-grad)"/>
                <text x="100" y="44" text-anchor="middle" font-family="'Space Grotesk',sans-serif" font-size="20" font-weight="700" fill="#fff" letter-spacing="2">ELFBAR</text>
                {% for row in 0..3 %}
                    <line x1="30" y1="{{ 78 + row * 46 }}" x2="170" y2="{{ 78 + row * 46 }}" stroke="rgba(255,255,255,0.18)" stroke-width="1"/>
                    {% for col in 0..3 %}
                        <rect x="{{ 36 + col * 33 }}" y="{{ 84 + row * 46 }}" width="20" height="34" rx="4" fill="url(#elfbar-vitrine-prod)" opacity="0.92"/>
                    {% endfor %}
                {% endfor %}
                <defs>
                    <linearGradient id="elfbar-vitrine-grad" x1="22" y1="14" x2="178" y2="60" gradientUnits="userSpaceOnUse">
                        <stop stop-color="#ff5ea7"/><stop offset="0.5" stop-color="#c85aff"/><stop offset="1" stop-color="#5a74ff"/>
                    </linearGradient>
                    <linearGradient id="elfbar-vitrine-prod" x1="0" y1="0" x2="0" y2="1">
                        <stop stop-color="#ffb3d4"/><stop offset="1" stop-color="#8a9bff"/>
                    </linearGradient>
                </defs>
            </svg>
        </div>
    </div>

    <div class="elfbar-vitrine__content">
        <p class="elfbar-vitrine__eyebrow">VITRINE PRO</p>
        <h2 class="elfbar-vitrine__title" id="elfbar-vitrine-title">Premium Verkaufs&shy;vitrine für Ihren Store</h2>
        <p class="elfbar-vitrine__text">
            Präsentieren Sie ELFBAR-Produkte stilvoll und verkaufsstark. Die VITRINE PRO ist abschließbar,
            beleuchtet und sofort einsatzbereit – das perfekte Highlight für Kiosk, Tankstelle und Fachhandel.
            Für Bestandskunden auf Wunsch kostenlos.
        </p>
        <ul class="elfbar-vitrine__features">
            <li>{% sw_icon 'check' %} Abschließbar &amp; LED-beleuchtet</li>
            <li>{% sw_icon 'check' %} Markenkonform gebrandet</li>
            <li>{% sw_icon 'check' %} Aufbau in unter 10 Minuten</li>
        </ul>
        <div class="elfbar-vitrine__actions">
            <a href="{{ path('frontend.account.register.page') }}" class="elfbar-btn elfbar-btn--gradient">
                Jetzt kostenlos anfragen {% sw_icon 'arrow-right' %}
            </a>
            <a href="#" class="elfbar-btn elfbar-btn--outline">
                Datenblatt Download
            </a>
        </div>
        <p class="elfbar-vitrine__note">* Nur für registrierte Gewerbetreibende. Abgabe ab 18 Jahren.</p>
    </div>
</section>

{# ============================================================
   2. WARUM ELFBAR B2B? — USP Grid
   ============================================================ #}
<section class="elfbar-usps" aria-labelledby="elfbar-usps-title">
    <header class="elfbar-section-head">
        <p class="elfbar-section-head__eyebrow">Ihre Vorteile</p>
        <h2 class="elfbar-section-head__title" id="elfbar-usps-title">Warum ELFBAR B2B?</h2>
        <p class="elfbar-section-head__sub">Der Großhandel, der für Ihren Erfolg gemacht ist.</p>
    </header>

    <div class="elfbar-usps__grid">
        <article class="elfbar-usp-card">
            <span class="elfbar-usp-card__icon">{% sw_icon 'bag-product' %}</span>
            <h3 class="elfbar-usp-card__title">Top-Margen für Händler</h3>
            <p class="elfbar-usp-card__text">Attraktive Staffelpreise und Mengenrabatte sichern Ihnen erstklassige Gewinnspannen.</p>
        </article>
        <article class="elfbar-usp-card">
            <span class="elfbar-usp-card__icon">{% sw_icon 'truck' %}</span>
            <h3 class="elfbar-usp-card__title">Schnelle Lieferung 24–48h</h3>
            <p class="elfbar-usp-card__text">Bestellt am Nachmittag, geliefert übermorgen – versandkostenfrei ab Mindestbestellwert.</p>
        </article>
        <article class="elfbar-usp-card">
            <span class="elfbar-usp-card__icon">{% sw_icon 'lock-closed' %}</span>
            <h3 class="elfbar-usp-card__title">Kauf auf Rechnung &amp; PayPal</h3>
            <p class="elfbar-usp-card__text">Flexible Zahlung für Gewerbekunden – sicher, geprüft und ohne Vorkasse-Zwang.</p>
        </article>
        <article class="elfbar-usp-card">
            <span class="elfbar-usp-card__icon">{% sw_icon 'headset' %}</span>
            <h3 class="elfbar-usp-card__title">Persönlicher B2B-Support</h3>
            <p class="elfbar-usp-card__text">Ihr fester Ansprechpartner berät Sie zu Sortiment, Aktionen und Nachschub.</p>
        </article>
    </div>
</section>

{# ============================================================
   3. UNSERE MARKENWELT — Brand World Banner Cards
   ============================================================ #}
<section class="elfbar-brandworld" aria-labelledby="elfbar-brandworld-title">
    <header class="elfbar-section-head">
        <p class="elfbar-section-head__eyebrow">Markenwelt</p>
        <h2 class="elfbar-section-head__title" id="elfbar-brandworld-title">Unsere Markenwelt</h2>
        <p class="elfbar-section-head__sub">Die stärksten Vape-Marken – exklusiv im B2B-Sortiment.</p>
    </header>

    <div class="elfbar-brandworld__grid">
        {% set elfbar_brands = [
            { letter: 'E', name: 'ELFBAR', desc: 'Der Bestseller. Einweg-Vapes in über 30 Geschmacksrichtungen.', tone: 'pink' },
            { letter: 'L', name: 'Lost Mary', desc: 'Trendiges Design trifft auf intensiven Geschmack.', tone: 'violet' },
            { letter: 'Q', name: 'ELFLIQ', desc: 'Premium-Liquids &amp; Nic-Salts für jedes Pod-System.', tone: 'blue' },
            { letter: 'A', name: 'ELFA', desc: 'Das nachfüllbare Pod-System der nächsten Generation.', tone: 'mix' }
        ] %}
        {% for brand in elfbar_brands %}
            <article class="elfbar-brand-card elfbar-brand-card--{{ brand.tone }}">
                <div class="elfbar-brand-card__media" aria-hidden="true">
                    <span class="elfbar-brand-card__letter">{{ brand.letter }}</span>
                </div>
                <div class="elfbar-brand-card__body">
                    <h3 class="elfbar-brand-card__name">{{ brand.name }}</h3>
                    <p class="elfbar-brand-card__desc">{{ brand.desc|raw }}</p>
                    <a href="#" class="elfbar-brand-card__link">Entdecken {% sw_icon 'arrow-right' %}</a>
                </div>
            </article>
        {% endfor %}
    </div>
</section>

{# ============================================================
   4. IN 3 SCHRITTEN ZUM HÄNDLER — Steps + FAQ
   ============================================================ #}
<section class="elfbar-howto" aria-labelledby="elfbar-howto-title">
    <header class="elfbar-section-head">
        <p class="elfbar-section-head__eyebrow">So einfach geht's</p>
        <h2 class="elfbar-section-head__title" id="elfbar-howto-title">In 3 Schritten zum Händler</h2>
        <p class="elfbar-section-head__sub">Von der Anmeldung bis zur ersten Bestellung in unter 24 Stunden.</p>
    </header>

    <ol class="elfbar-steps">
        <li class="elfbar-step">
            <span class="elfbar-step__num">1</span>
            <span class="elfbar-step__icon">{% sw_icon 'rocket' %}</span>
            <h3 class="elfbar-step__title">Registrieren</h3>
            <p class="elfbar-step__text">Gewerbedaten eingeben und Konto kostenlos erstellen.</p>
        </li>
        <li class="elfbar-step">
            <span class="elfbar-step__num">2</span>
            <span class="elfbar-step__icon">{% sw_icon 'lock-closed' %}</span>
            <h3 class="elfbar-step__title">Freischaltung</h3>
            <p class="elfbar-step__text">Wir prüfen Ihren Gewerbenachweis – meist innerhalb weniger Stunden.</p>
        </li>
        <li class="elfbar-step">
            <span class="elfbar-step__num">3</span>
            <span class="elfbar-step__icon">{% sw_icon 'bag-product' %}</span>
            <h3 class="elfbar-step__title">Bestellen</h3>
            <p class="elfbar-step__text">Großhandelspreise sehen, Sortiment wählen und losbestellen.</p>
        </li>
    </ol>

    <div class="elfbar-howto__cta">
        <a href="{{ path('frontend.account.register.page') }}" class="elfbar-btn elfbar-btn--gradient">
            Jetzt Händlerkonto erstellen {% sw_icon 'arrow-right' %}
        </a>
    </div>

    <div class="elfbar-faq">
        <h3 class="elfbar-faq__head">Häufige Fragen</h3>

        <div class="elfbar-faq__item">
            <button type="button" class="elfbar-faq__q">
                <span>Wer kann sich als Händler registrieren?</span>
                <span class="elfbar-faq__chev" aria-hidden="true">{% sw_icon 'arrow-right' %}</span>
            </button>
            <div class="elfbar-faq__a">
                <p>Die Registrierung ist ausschließlich Gewerbetreibenden mit gültigem Gewerbenachweis vorbehalten. Privatverkauf ist ausgeschlossen.</p>
            </div>
        </div>

        <div class="elfbar-faq__item">
            <button type="button" class="elfbar-faq__q">
                <span>Wie hoch ist der Mindestbestellwert?</span>
                <span class="elfbar-faq__chev" aria-hidden="true">{% sw_icon 'arrow-right' %}</span>
            </button>
            <div class="elfbar-faq__a">
                <p>Der Mindestbestellwert liegt bei 250 € netto. Ab 500 € netto liefern wir versandkostenfrei innerhalb Deutschlands.</p>
            </div>
        </div>

        <div class="elfbar-faq__item">
            <button type="button" class="elfbar-faq__q">
                <span>Welche Zahlungsarten stehen zur Verfügung?</span>
                <span class="elfbar-faq__chev" aria-hidden="true">{% sw_icon 'arrow-right' %}</span>
            </button>
            <div class="elfbar-faq__a">
                <p>Wir bieten Kauf auf Rechnung, PayPal, Kreditkarte und Vorkasse. Kauf auf Rechnung ist nach erfolgreicher Bonitätsprüfung verfügbar.</p>
            </div>
        </div>

        <div class="elfbar-faq__item">
            <button type="button" class="elfbar-faq__q">
                <span>Wie schnell wird geliefert?</span>
                <span class="elfbar-faq__chev" aria-hidden="true">{% sw_icon 'arrow-right' %}</span>
            </button>
            <div class="elfbar-faq__a">
                <p>Bestellungen, die werktags bis 14 Uhr eingehen, versenden wir noch am selben Tag. Die Zustellung erfolgt in der Regel innerhalb von 24–48 Stunden.</p>
            </div>
        </div>
    </div>
</section>

{# ============================================================
   5. ÜBER 4.000 ZUFRIEDENE HÄNDLER — Reviews + Trust
   ============================================================ #}
<section class="elfbar-reviews" aria-labelledby="elfbar-reviews-title">
    <header class="elfbar-section-head">
        <p class="elfbar-section-head__eyebrow">Vertrauen &amp; Qualität</p>
        <h2 class="elfbar-section-head__title" id="elfbar-reviews-title">Über 4.000 zufriedene Händler</h2>
        <p class="elfbar-section-head__sub">Das sagen unsere Partner aus dem Fachhandel.</p>
    </header>

    <div class="elfbar-reviews__grid">
        {% set elfbar_reviews = [
            { text: 'Lieferung am nächsten Tag, top Margen und ein Ansprechpartner, der wirklich erreichbar ist. Genau so muss B2B sein.', name: 'Murat K.', firm: 'Kiosk am Bahnhof, Köln' },
            { text: 'Die VITRINE PRO hat unseren Vape-Umsatz spürbar gesteigert. Kunden greifen einfach öfter zu. Klare Empfehlung.', name: 'Sandra B.', firm: 'Tankstelle Nord, Hamburg' },
            { text: 'Riesige Auswahl, faire Staffelpreise und Kauf auf Rechnung ohne Stress. Wir bestellen seit über einem Jahr regelmäßig.', name: 'Daniel R.', firm: 'Vape Store, München' }
        ] %}
        {% for review in elfbar_reviews %}
            <article class="elfbar-review-card">
                <div class="elfbar-review-card__stars" aria-label="5 von 5 Sternen">
                    {% for i in 1..5 %}{% sw_icon 'star' %}{% endfor %}
                </div>
                <p class="elfbar-review-card__text">{{ review.text }}</p>
                <footer class="elfbar-review-card__author">
                    <span class="elfbar-review-card__avatar" aria-hidden="true">{{ review.name|first }}</span>
                    <span class="elfbar-review-card__meta">
                        <strong>{{ review.name }}</strong>
                        <span>{{ review.firm }}</span>
                    </span>
                </footer>
            </article>
        {% endfor %}
    </div>

    <div class="elfbar-trust">
        <span class="elfbar-trust__badge">{% sw_icon 'check' %} Trusted Shops</span>
        <span class="elfbar-trust__badge">{% sw_icon 'lock-closed' %} SSL-verschlüsselt</span>
        <span class="elfbar-trust__badge">{% sw_icon 'check' %} Käuferschutz</span>
        <span class="elfbar-trust__badge">{% sw_icon 'star' %} 4,8 / 5 Bewertung</span>
    </div>
</section>
